    "nodeVersion": "20",
    "adminUi": "json",
    "tools": ["ESLint", "Prettier"],
    "eslintConfig": "official",
    "releaseScript": "yes",
    "devServer": "local",
    "indentation": "Space (4)",
    "quotes": "double",
    "authorName": "Maximilian Kramer",
    "authorGithub": "maxik690",
    "authorEmail": "maxi_kramer@web.de",
    "gitRemoteProtocol": "SSH",
    "gitCommit": "yes",
    "defaultBranch": "main",
    "license": "MIT License",
    "dependabot": "yes",
    "creatorVersion": "3.1.2"
